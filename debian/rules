#!/usr/bin/make -f

DEB_HOST_ARCH ?= $(shell dpkg-architecture -qDEB_HOST_ARCH)
DEB_BUILD_DIR := build

override_dh_auto_configure:
	mkdir -p $(DEB_BUILD_DIR)
	cd $(DEB_BUILD_DIR) && cmake -DCMAKE_INSTALL_PREFIX=/usr ..

override_dh_auto_build:
	cd $(DEB_BUILD_DIR) && make -j$(shell nproc)

override_dh_auto_install:
	mkdir -p debian/speedfetch/usr/bin
	cp $(DEB_BUILD_DIR)/speedfetch debian/speedfetch/usr/bin/

override_dh_auto_clean:
	rm -rf $(DEB_BUILD_DIR)

%:
	dh $@
